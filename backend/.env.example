# Variables de entorno requeridas en el VPS (copiar a .env y completar)

# URL de la base de datos PostgreSQL (Neon u otro proveedor)
DATABASE_URL=postgresql://usuario:password@host/dbname?sslmode=require

# Clave secreta para firmar tokens JWT (cambiar en produccion)
JWT_SECRET_KEY=cambiar-esta-clave-en-produccion

# Usar PostgreSQL (true) o SQLite local (false)
USE_NEON=true
